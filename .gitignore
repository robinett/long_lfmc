!lfmc_model/scripts/inference/old/
!lfmc_model/scripts/inference/old/orchestrate_low_latency_monthly_update.sh
!lfmc_model/scripts/inference/old/submit_low_latency_month_promotion.sh
!/old/
/old/*
!/old/viewer/
!/old/viewer/**
lfmc_model/scripts/transfer_out/source_credentials.json

# Ignore dotfiles EXCEPT .gitignore
**/.*
!.gitignore
